@model List<LibraryManagementSystem.Models.Entities.Book>
@{
    ViewData["Title"] = "Browse Books";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-search me-2 text-primary"></i>Browse Books
    </h4>
    <a href="/Student/MyRequests" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-bell me-1"></i>My Requests
    </a>
</div>

<div id="alert-box" class="d-none mb-3"></div>

<!-- Search + Filter -->
<div class="row g-2 mb-3">
    <div class="col-md-5">
        <input type="text" id="search-books"
               class="form-control" placeholder="Search by title, author or code..." />
    </div>
    <div class="col-md-3">
        <select id="filter-availability" class="form-select">
            <option value="all">All Books</option>
            <option value="available">Available Only</option>
            <option value="unavailable">Unavailable</option>
        </select>
    </div>
</div>

<!-- Book Cards Grid -->
<div class="row g-3" id="books-grid">
    @foreach (var book in Model)
    {
        var available = book.AvailableQuantity > 0;
        <div class="col-xl-3 col-lg-4 col-md-6 book-card-col"
             data-name="@book.BookName.ToLower()"
             data-author="@book.AuthorName.ToLower()"
             data-code="@book.BookCode.ToLower()"
             data-available="@(available ? "available" : "unavailable")">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <span class="badge @(available ? "bg-success" : "bg-secondary")">
                            @(available ? $"{book.AvailableQuantity} available" : "Unavailable")
                        </span>
                        <small class="text-muted"><code>@book.BookCode</code></small>
                    </div>
                    <h6 class="fw-bold mb-1">@book.BookName</h6>
                    <p class="text-muted small mb-0">
                        <i class="bi bi-person me-1"></i>@book.AuthorName
                    </p>
                    <p class="text-muted small mb-3">
                        <i class="bi bi-stack me-1"></i>Total: @book.TotalQuantity copies
                    </p>
                    <div class="mt-auto">
                        @if (available)
                        {
                            <button class="btn btn-primary btn-sm w-100 btn-request"
                                    data-id="@book.BookId"
                                    data-name="@book.BookName">
                                <i class="bi bi-send me-1"></i>Request Book
                            </button>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm w-100" disabled>
                                <i class="bi bi-x-circle me-1"></i>Not Available
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    @if (!Model.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-journal-x fs-1 d-block mb-2"></i>
            No books in the library yet.
        </div>
    }
</div>

<!-- Confirm Request Modal -->
<div class="modal fade" id="requestModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h6 class="modal-title fw-bold text-primary">
                    <i class="bi bi-send me-2"></i>Request Book
                </h6>
                <button class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p>You are requesting: <strong id="request-book-name"></strong></p>
                <div class="alert alert-info py-2 small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    The librarian will review and approve your request.
                    Default issue period is <strong>14 days</strong>.
                    Fine of <strong>₹10/day</strong> applies after due date.
                </div>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-primary btn-sm" id="confirm-request">
                    <i class="bi bi-send me-1"></i>Submit Request
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let requestBookId = null;
        const requestModal = new bootstrap.Modal(document.getElementById('requestModal'));

        // Open request modal
        $(document).on('click', '.btn-request', function () {
            requestBookId = $(this).data('id');
            $('#request-book-name').text($(this).data('name'));
            requestModal.show();
        });

        // Confirm request
        $('#confirm-request').on('click', function () {
            const btn = $(this).prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm me-1"></span>Submitting...');

            $.post('/Student/RequestBook', { bookId: requestBookId }, function (res) {
                requestModal.hide();
                showAlert(res.success ? 'success' : 'danger', res.message);
            }).always(() => {
                btn.prop('disabled', false).html('<i class="bi bi-send me-1"></i>Submit Request');
            });
        });

        // Search
        $('#search-books').on('keyup', function () {
            applyFilters();
        });

        // Availability filter
        $('#filter-availability').on('change', function () {
            applyFilters();
        });

        function applyFilters() {
            const q = $('#search-books').val().toLowerCase();
            const av = $('#filter-availability').val();

            $('.book-card-col').each(function () {
                const name    = $(this).data('name');
                const author  = $(this).data('author');
                const code    = $(this).data('code');
                const avail   = $(this).data('available');

                const matchQ  = !q || name.includes(q) || author.includes(q) || code.includes(q);
                const matchAv = av === 'all' || avail === av;

                $(this).toggle(matchQ && matchAv);
            });
        }

        function showAlert(type, msg) {
            $('#alert-box')
                .removeClass('d-none alert-success alert-danger alert-warning')
                .addClass(`alert alert-${type}`)
                .html(`<i class="bi bi-${type === 'success' ? 'check-circle' : 'x-circle'} me-2"></i>${msg}`);
            $('html,body').animate({ scrollTop: 0 }, 300);
        }
    </script>
}