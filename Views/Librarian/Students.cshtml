@model List<LibraryManagementSystem.Models.Entities.User>
@{
    ViewData["Title"] = "Registered Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people me-2 text-info"></i>Registered Students</h4>
    <span class="badge bg-secondary fs-6">@Model.Count total</span>
</div>

<div class="mb-3">
    <input type="text" id="search-students" class="form-control" placeholder="Search by name or email..." style="max-width:400px" />
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" id="students-table">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Registered On</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (s, i) in Model.Select((s, i) => (s, i + 1)))
                    {
                        <tr>
                            <td class="ps-3 text-muted">@i</td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td class="text-muted">@s.Email</td>
                            <td class="small">@s.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success" : "bg-danger")">
                                    @(s.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-5">No students registered yet.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('#search-students').on('keyup', function () {
            const q = $(this).val().toLowerCase();
            $('#students-table tbody tr').each(function () {
                $(this).toggle($(this).text().toLowerCase().includes(q));
            });
        });
    </script>
}