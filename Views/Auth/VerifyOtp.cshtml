@model LibraryManagementSystem.Models.ViewModels.OtpVerifyViewModel
@{
    ViewData["Title"] = "Verify OTP";
    Layout = null;
    var purposeLabel = Model.Purpose switch
    {
        "StudentRegister" => "Email Verification",
        "StudentLogin" => "Login Verification",
        "LibrarianLogin" => "Librarian Verification",
        _ => "Verification"
    };
    var iconClass = Model.Purpose == "LibrarianLogin" ? "bi-person-badge text-warning"
                  : "bi-shield-lock text-info";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify OTP — Library MS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        body {
            background: linear-gradient(135deg, #1a1a2e, #0f3460);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .otp-input {
            letter-spacing: 12px;
            font-size: 28px;
            font-weight: bold;
            text-align: center;
        }

            .otp-input:focus {
                border-color: #3498db;
                box-shadow: 0 0 0 0.2rem rgba(52,152,219,.25);
            }

        #countdown {
            font-weight: bold;
            color: #3498db;
        }

            #countdown.expired {
                color: #e74c3c;
            }
    </style>
</head>
<body>
    <div style="width:100%;max-width:440px" class="px-3">
        <div class="card bg-dark text-white shadow-lg border-0 rounded-4 p-4">

            <div class="text-center mb-4">
                <i class="bi @iconClass" style="font-size:48px"></i>
                <h4 class="fw-bold mt-2">@purposeLabel</h4>
                <p class="text-white-50 small mb-0">
                    OTP sent to <strong>@Model.Email</strong>
                </p>
            </div>

            @if (TempData["Info"] != null)
            {
                <div class="alert alert-info py-2 small">@TempData["Info"]</div>
            }

            <form id="otp-form" method="post" asp-action="VerifyOtp">
                <input type="hidden" asp-for="Email" />
                <input type="hidden" asp-for="Purpose" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger py-2 small mb-3">
                        @foreach (var error in ViewData.ModelState.Values
                                            .SelectMany(v => v.Errors))
                        {
                            <div>@error.ErrorMessage</div>
                        }
                    </div>
                }

                <div class="mb-4">
                    <label class="form-label small text-white-50">Enter 6-digit OTP</label>
                    <input asp-for="OtpCode"
                           id="otp-input"
                           class="form-control bg-secondary border-0 text-white otp-input"
                           placeholder="______"
                           maxlength="6"
                           autocomplete="one-time-code"
                           inputmode="numeric" />
                    <div class="text-center mt-2">
                        <small class="text-white-50">
                            Expires in <span id="countdown">10:00</span>
                        </small>
                    </div>
                </div>

                <button type="submit"
                        id="btn-verify"
                        class="btn btn-info w-100 fw-bold text-white mb-3">
                    <i class="bi bi-shield-check me-1"></i>Verify OTP
                </button>
            </form>

            <!-- Resend OTP -->
            <div class="text-center">
                <span class="text-white-50 small">Didn't receive OTP?</span>
                <button class="btn btn-link btn-sm text-info p-0 ms-1"
                        id="btn-resend" disabled>
                    Resend OTP
                </button>
            </div>

            <div id="resend-msg" class="text-center mt-2 small d-none"></div>

            <div class="text-center mt-3">
                <a href="/Auth/Login" class="text-white-50 small text-decoration-none">
                    <i class="bi bi-arrow-left me-1"></i>Back to login
                </a>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        // ── Prevent double submit ─────────────────────────
        let submitted = false;

        $('#otp-form').on('submit', function (e) {
            if (submitted) {
                e.preventDefault();
                return false;
            }

            // Strip spaces and non-digits from OTP
            const raw = $('#otp-input').val();
            const clean = raw.replace(/\D/g, '');
            $('#otp-input').val(clean);

            if (clean.length !== 6) {
                e.preventDefault();
                alert('Please enter a valid 6-digit OTP.');
                return false;
            }

            submitted = true;
            $('#btn-verify')
                .prop('disabled', true)
                .html('<span class="spinner-border spinner-border-sm me-2"></span>Verifying...');
        });

        // ── Countdown timer ───────────────────────────────
        let seconds = 600;
        let resendAllowed = false;

        const timer = setInterval(() => {
            seconds--;
            const m = Math.floor(seconds / 60).toString().padStart(2, '0');
            const s = (seconds % 60).toString().padStart(2, '0');
            $('#countdown').text(`${m}:${s}`);

            if (seconds <= 0) {
                clearInterval(timer);
                $('#countdown').text('Expired').addClass('expired');
                $('#btn-resend').prop('disabled', false);
            }

            if (seconds <= 540 && !resendAllowed) {
                resendAllowed = true;
                $('#btn-resend').prop('disabled', false);
            }
        }, 1000);

        // ── Resend OTP ────────────────────────────────────
        $('#btn-resend').on('click', function () {
            $(this).prop('disabled', true);
            $.post('/Auth/ResendOtp', {
                email:   '@Model.Email',
                purpose: '@Model.Purpose'
            }, function (res) {
                $('#resend-msg')
                    .removeClass('d-none text-success text-danger')
                    .addClass(`text-${res.success ? 'success' : 'danger'}`)
                    .text(res.message);

                if (res.success) {
                    seconds = 600;
                    resendAllowed = false;
                    submitted = false;
                    $('#btn-verify')
                        .prop('disabled', false)
                        .html('<i class="bi bi-shield-check me-1"></i>Verify OTP');
                }
            });
        });

        // ── Only allow digits in OTP input ───────────────
        $('#otp-input').on('input', function () {
            this.value = this.value.replace(/\D/g, '');
        });
    </script>
</body>
</html>