<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Library MS</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * {
            font-family: 'Inter', sans-serif;
        }

        body {
            background: #f0f2f5;
            min-height: 100vh;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 250px;
            min-height: 100vh;
            background: linear-gradient(180deg, #0f0c29 0%, #302b63 50%, #24243e 100%);
            position: fixed;
            top: 0;
            left: 0;
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: width 0.3s;
            box-shadow: 4px 0 20px rgba(0,0,0,0.3);
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,0.08);
        }

            .sidebar-brand h5 {
                color: #fff;
                font-weight: 700;
                font-size: 18px;
                margin: 0;
                letter-spacing: 0.5px;
            }

            .sidebar-brand span {
                font-size: 11px;
                color: rgba(255,255,255,0.4);
                letter-spacing: 1px;
                text-transform: uppercase;
            }

        .sidebar-nav {
            padding: 16px 0;
            flex: 1;
        }

        .nav-section-label {
            font-size: 10px;
            font-weight: 600;
            letter-spacing: 1.5px;
            text-transform: uppercase;
            color: rgba(255,255,255,0.3);
            padding: 12px 20px 6px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 11px 20px;
            color: rgba(255,255,255,0.65);
            text-decoration: none;
            font-size: 14px;
            font-weight: 400;
            transition: all 0.2s;
            border-left: 3px solid transparent;
            margin: 1px 0;
        }

            .sidebar-link:hover {
                background: rgba(255,255,255,0.08);
                color: #fff;
                border-left-color: rgba(255,255,255,0.3);
            }

            .sidebar-link.active {
                background: rgba(99,102,241,0.25);
                color: #fff;
                border-left-color: #6366f1;
                font-weight: 500;
            }

            .sidebar-link i {
                font-size: 16px;
                width: 20px;
            }

            .sidebar-link .badge-pill {
                margin-left: auto;
                background: #6366f1;
                color: #fff;
                font-size: 10px;
                padding: 2px 7px;
                border-radius: 10px;
            }

        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid rgba(255,255,255,0.08);
        }

        .user-pill {
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .user-avatar {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            font-size: 14px;
            color: #fff;
            flex-shrink: 0;
        }

        .user-info {
            flex: 1;
            overflow: hidden;
        }

            .user-info .name {
                color: #fff;
                font-size: 13px;
                font-weight: 500;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .user-info .role {
                color: rgba(255,255,255,0.4);
                font-size: 11px;
            }

        /* ── Main Content ── */
        .main-content {
            margin-left: 250px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
        }

        /* ── Top bar ── */
        .topbar {
            background: #fff;
            padding: 14px 28px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid #e8eaf0;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .topbar-title {
            font-size: 18px;
            font-weight: 600;
            color: #1a1a2e;
            margin: 0;
        }

        .topbar-right {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .btn-logout {
            background: #fff0f0;
            color: #e74c3c;
            border: 1px solid #ffd5d5;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            text-decoration: none;
            transition: all 0.2s;
        }

            .btn-logout:hover {
                background: #e74c3c;
                color: #fff;
            }

        /* ── Page body ── */
        .page-body {
            padding: 28px;
            flex: 1;
        }

        /* ── Stat Cards ── */
        .stat-card {
            border-radius: 16px;
            padding: 22px;
            color: #fff;
            position: relative;
            overflow: hidden;
            border: none;
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .stat-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 12px 32px rgba(0,0,0,0.15);
            }

            .stat-card .stat-icon {
                position: absolute;
                right: 16px;
                top: 16px;
                font-size: 42px;
                opacity: 0.2;
            }

            .stat-card .stat-number {
                font-size: 36px;
                font-weight: 700;
                line-height: 1;
                margin-bottom: 4px;
            }

            .stat-card .stat-label {
                font-size: 13px;
                opacity: 0.85;
                font-weight: 400;
            }

            .stat-card .stat-sub {
                font-size: 11px;
                opacity: 0.65;
                margin-top: 8px;
            }

        .card-blue {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .card-green {
            background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
        }

        .card-orange {
            background: linear-gradient(135deg, #f7971e 0%, #ffd200 100%);
        }

        .card-purple {
            background: linear-gradient(135deg, #8e2de2 0%, #4a00e0 100%);
        }

        .card-red {
            background: linear-gradient(135deg, #eb3349 0%, #f45c43 100%);
        }

        .card-teal {
            background: linear-gradient(135deg, #1a6dff 0%, #00d4aa 100%);
        }

        /* ── Quick Action Cards ── */
        .action-card {
            background: #fff;
            border-radius: 14px;
            padding: 20px;
            text-align: center;
            text-decoration: none;
            display: block;
            transition: all 0.2s;
            border: 1px solid #eef0f5;
            color: #333;
        }

            .action-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 24px rgba(0,0,0,0.1);
                color: #333;
            }

        .action-icon {
            width: 52px;
            height: 52px;
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 12px;
            font-size: 22px;
        }

        /* ── Section Cards ── */
        .section-card {
            background: #fff;
            border-radius: 16px;
            border: none;
            box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        }

            .section-card .card-header {
                background: transparent;
                border-bottom: 1px solid #f0f2f5;
                padding: 18px 22px 14px;
            }

        /* ── Table ── */
        .table th {
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: #8892a4;
            border-bottom: 1px solid #f0f2f5;
            padding: 10px 14px;
        }

        .table td {
            padding: 12px 14px;
            vertical-align: middle;
            font-size: 14px;
        }

        .table tbody tr {
            border-bottom: 1px solid #f8f9fb;
        }

            .table tbody tr:last-child {
                border-bottom: none;
            }

            .table tbody tr:hover {
                background: #f8f9ff;
            }

        /* ── Badges ── */
        .badge {
            font-weight: 500;
            font-size: 11px;
            padding: 4px 10px;
            border-radius: 6px;
        }

        /* No sidebar for auth pages */
        .auth-page .sidebar {
            display: none;
        }

        .auth-page .main-content {
            margin-left: 0;
        }
    </style>
</head>
<body>

    @{
        var userType = Context.Session.GetString("UserType");
        var fullName = Context.Session.GetString("FullName") ?? "";
        var initial = fullName.Length > 0 ? fullName[0].ToString().ToUpper() : "U";
        var avatarColor = userType == "Admin" ? "#e74c3c"
        : userType == "Librarian" ? "#6366f1"
        : "#10b981";
        var currentPath = Context.Request.Path.Value ?? "";
    }

    @if (userType != null)
    {
        <!-- ── Sidebar ── -->
        <div class="sidebar">
            <div class="sidebar-brand">
                <div class="d-flex align-items-center gap-2">
                    <div style="width:36px;height:36px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:10px;display:flex;align-items:center;justify-content:center">
                        <i class="bi bi-book-half text-white" style="font-size:18px"></i>
                    </div>
                    <div>
                        <h5>Library MS</h5>
                        <span>Management System</span>
                    </div>
                </div>
            </div>

            <div class="sidebar-nav">
                @if (userType == "Admin")
                {
                    <div class="nav-section-label">Admin Panel</div>
                    <a href="/Admin/Dashboard"
                       class="sidebar-link @(currentPath.Contains("/Admin/Dashboard") ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="/Admin/EditLibrarian"
                       class="sidebar-link @(currentPath.Contains("/Admin/EditLibrarian") ? "active" : "")">
                        <i class="bi bi-person-gear"></i> Manage Librarian
                    </a>
                    <a href="/Admin/Students"
                       class="sidebar-link @(currentPath.Contains("/Admin/Students") ? "active" : "")">
                        <i class="bi bi-people"></i> Students
                    </a>
                }
                else if (userType == "Librarian")
                {
                    <div class="nav-section-label">Library</div>
                    <a href="/Librarian/Dashboard"
                       class="sidebar-link @(currentPath == "/Librarian/Dashboard" ? "active" : "")">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="/Librarian/AddBooks"
                       class="sidebar-link @(currentPath.Contains("/Librarian/AddBooks") ? "active" : "")">
                        <i class="bi bi-plus-circle"></i> Add Books
                    </a>
                    <a href="/Librarian/Books"
                       class="sidebar-link @(currentPath.Contains("/Librarian/Books") ? "active" : "")">
                        <i class="bi bi-journals"></i> Book Inventory
                    </a>

                    <div class="nav-section-label" style="margin-top:8px">Management</div>
                    <a href="/Librarian/Requests"
                       class="sidebar-link @(currentPath.Contains("/Librarian/Requests") ? "active" : "")">
                        <i class="bi bi-bell"></i> Book Requests
                    </a>
                    <a href="/Librarian/IssuedBooks"
                       class="sidebar-link @(currentPath.Contains("/Librarian/IssuedBooks") ? "active" : "")">
                        <i class="bi bi-journal-check"></i> Issued Books
                    </a>
                    <a href="/Librarian/Students"
                       class="sidebar-link @(currentPath.Contains("/Librarian/Students") ? "active" : "")">
                        <i class="bi bi-people"></i> Students
                    </a>
                }
                else if (userType == "Student")
                {
                    <div class="nav-section-label">My Library</div>
                    <a href="/Student/Dashboard"
                       class="sidebar-link @(currentPath == "/Student/Dashboard" ? "active" : "")">
                        <i class="bi bi-house"></i> Dashboard
                    </a>
                    <a href="/Student/Books"
                       class="sidebar-link @(currentPath.Contains("/Student/Books") ? "active" : "")">
                        <i class="bi bi-search"></i> Browse Books
                    </a>
                    <a href="/Student/MyBooks"
                       class="sidebar-link @(currentPath.Contains("/Student/MyBooks") ? "active" : "")">
                        <i class="bi bi-journal-check"></i> My Issued Books
                    </a>
                    <a href="/Student/MyRequests"
                       class="sidebar-link @(currentPath.Contains("/Student/MyRequests") ? "active" : "")">
                        <i class="bi bi-clock-history"></i> My Requests
                    </a>
                }
            </div>

            <div class="sidebar-footer">
                <div class="user-pill">
                    <div class="user-avatar" style="background:@avatarColor">
                        @initial
                    </div>
                    <div class="user-info">
                        <div class="name">@fullName</div>
                        <div class="role">@userType</div>
                    </div>
                    <a href="/Auth/Logout" title="Logout"
                       style="color:rgba(255,255,255,0.4);font-size:16px;text-decoration:none">
                        <i class="bi bi-box-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <!-- ── Main Content ── -->
        <div class="main-content">
            <div class="topbar">
                <h1 class="topbar-title">@ViewData["Title"]</h1>
                <div class="topbar-right">
                    <span style="font-size:13px;color:#8892a4">
                        <i class="bi bi-clock me-1"></i>
                        @DateTime.Now.ToString("dd MMM yyyy")
                    </span>
                    <a href="/Auth/Logout" class="btn-logout">
                        <i class="bi bi-box-arrow-right me-1"></i>Logout
                    </a>
                </div>
            </div>
            <div class="page-body">
                @RenderBody()
            </div>
        </div>
    }
    else
    {
        @RenderBody()
    }

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>