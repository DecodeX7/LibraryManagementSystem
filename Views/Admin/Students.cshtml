@model List<LibraryManagementSystem.Models.Entities.User>
@{
    ViewData["Title"] = "Manage Students";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-people me-2 text-primary"></i>Manage Students
    </h4>
    <div class="d-flex gap-2 align-items-center">
        <span class="badge bg-primary">Total: @Model.Count</span>
        <span class="badge bg-success">Active: @Model.Count(s => s.IsActive)</span>
        <span class="badge bg-danger">Inactive: @Model.Count(s => !s.IsActive)</span>
    </div>
</div>

<div id="alert-box" class="d-none mb-3"></div>

<div class="mb-3">
    <input type="text" id="search-students" class="form-control"
           placeholder="Search by name or email..." style="max-width:400px" />
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0 align-middle" id="students-table">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">#</th>
                        <th>Full Name</th>
                        <th>Email</th>
                        <th>Registered On</th>
                        <th>Status</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (s, i) in Model.Select((s, i) => (s, i + 1)))
                    {
                        <tr id="row-@s.UserId">
                            <td class="ps-3 text-muted">@i</td>
                            <td class="fw-semibold">@s.FullName</td>
                            <td class="text-muted">@s.Email</td>
                            <td class="small">@s.CreatedAt.ToString("dd MMM yyyy")</td>
                            <td>
                                <span class="badge @(s.IsActive ? "bg-success" : "bg-danger")"
                                      id="badge-@s.UserId">
                                    @(s.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td>
                                <button class="btn btn-sm @(s.IsActive ? "btn-outline-danger" : "btn-outline-success") btn-toggle-student"
                                        data-id="@s.UserId"
                                        data-name="@s.FullName"
                                        data-active="@s.IsActive.ToString().ToLower()">
                                    @(s.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                No students registered yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Search
        $('#search-students').on('keyup', function () {
            const q = $(this).val().toLowerCase();
            $('#students-table tbody tr').each(function () {
                $(this).toggle($(this).text().toLowerCase().includes(q));
            });
        });

        // Toggle student status
        $(document).on('click', '.btn-toggle-student', function () {
            const id     = $(this).data('id');
            const name   = $(this).data('name');
            const active = $(this).data('active') === 'true';
            const action = active ? 'deactivate' : 'activate';

            if (!confirm(`Are you sure you want to ${action} ${name}?`)) return;

            const btn = $(this).prop('disabled', true);

            $.post('/Admin/ToggleStudentStatus', { studentId: id }, function (res) {
                if (res.success) {
                    showAlert('success', res.message);
                    // Update badge
                    const newActive = !active;
                    $(`#badge-${id}`)
                        .text(newActive ? 'Active' : 'Inactive')
                        .removeClass('bg-success bg-danger')
                        .addClass(newActive ? 'bg-success' : 'bg-danger');
                    // Update button
                    btn.text(newActive ? 'Deactivate' : 'Activate')
                       .removeClass('btn-outline-success btn-outline-danger')
                       .addClass(newActive ? 'btn-outline-danger' : 'btn-outline-success')
                       .data('active', newActive.toString());
                } else {
                    showAlert('danger', res.message);
                }
            }).always(() => btn.prop('disabled', false));
        });

        function showAlert(type, msg) {
            $('#alert-box')
                .removeClass('d-none alert-success alert-danger')
                .addClass(`alert alert-${type}`)
                .text(msg);
        }
    </script>
}